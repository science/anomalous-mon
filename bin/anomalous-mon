#!/usr/bin/env bash
# anomalous-mon — Desktop anomaly monitor
#
# Monitors for sustained CPU hogging and OOM kills on a Linux workstation.
# Designed to run as a systemd user timer (every 60s).
#
# Usage:
#   anomalous-mon           Run one monitoring cycle
#   anomalous-mon --status  Show current tracking state

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

# Load configuration
source "$PROJECT_DIR/etc/anomalous-mon.conf"

# Load libraries
source "$PROJECT_DIR/lib/notify.sh"
source "$PROJECT_DIR/lib/cpu-monitor.sh"
source "$PROJECT_DIR/lib/journal-monitor.sh"

# Runtime state files
STATE_DIR="${XDG_RUNTIME_DIR:-/tmp}"
CPU_STATE_FILE="${STATE_DIR}/anomalous-mon.state"
JOURNAL_CURSOR_FILE="${STATE_DIR}/anomalous-mon.cursor"
JOURNAL_ALERT_FILE="${STATE_DIR}/anomalous-mon.oom-alerts"

# Handle --status
if [[ "${1:-}" == "--status" ]]; then
    cpu_status "$CPU_STATE_FILE"
    echo ""
    if [[ -f "$JOURNAL_CURSOR_FILE" ]]; then
        echo "Journal cursor: $(cat "$JOURNAL_CURSOR_FILE")"
    else
        echo "Journal cursor: none (will scan recent window on next run)"
    fi
    exit 0
fi

# Run one monitoring cycle
cpu_sample "$CPU_STATE_FILE" "$CPU_THRESHOLD" "$CPU_THRESHOLD_TOTAL"
cpu_check_alerts "$CPU_STATE_FILE" "$CPU_SUSTAINED_CYCLES"
journal_check "$JOURNAL_CURSOR_FILE" "$OOM_LOOKBACK" "$JOURNAL_ALERT_FILE" "$OOM_COOLDOWN"

# Log tracking state if anything is being tracked
_load_state "$CPU_STATE_FILE"
if (( ${#_PID_COUNT[@]} > 0 || ${#_NAME_COUNT[@]} > 0 )); then
    for pid in "${!_PID_COUNT[@]}"; do
        local_flag=""
        local_name="${_PID_NAME[$pid]}"
        local_cycles="$(_get_sustained_cycles "$local_name" "$CPU_SUSTAINED_CYCLES")"
        [[ "${_PID_ALERTED[$pid]:-0}" == "1" ]] && local_flag=" ALERTED"
        echo "[tracking] PID ${pid} (${local_name}): ${_PID_COUNT[$pid]}/${local_cycles} cycles${local_flag} — ${_PID_ARGS[$pid]:-}"
    done
    for name in "${!_NAME_COUNT[@]}"; do
        local_flag=""
        local_cycles="$(_get_sustained_cycles "$name" "$CPU_SUSTAINED_CYCLES")"
        [[ "${_NAME_ALERTED[$name]:-0}" == "1" ]] && local_flag=" ALERTED"
        echo "[tracking] name '${name}': ${_NAME_COUNT[$name]}/${local_cycles} cycles${local_flag}"
    done
fi
